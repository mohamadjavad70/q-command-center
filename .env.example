OPENAI_API_KEY=your_openai_api_key_here
PORT=3001
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2

# Optional API rate limit settings for server.js
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX_REQUESTS=30
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX_REQUESTS=10

# Backend API base URL — leave empty for same-domain deployment, or set to external backend URL
# Example for local dev: VITE_API_BASE_URL=http://localhost:3001
# Example for production: VITE_API_BASE_URL=https://api.qmetaram.com
VITE_API_BASE_URL=

# Supabase — client-side
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...your_anon_key_here
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.2

# Supabase — server-side only (NEVER expose in frontend)
# Required by server.js for user_memory read/write
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sk_...your_service_role_key_here

# Auth enforcement — set true to require Supabase JWT on /memory and /conversations
REQUIRE_AUTH=false

# Ollama (optional — local LLM fallback used by QNativeChat)
# VITE_OLLAMA_URL=http://localhost:11434
